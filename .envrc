export SOPS_AGE_KEY_FILE=~/.config/sops/age/K3s-Flux.agekey

export TALOSCONFIG=$(expand_path ./talos/clusterconfig/talosconfig)

export KUBECONFIG=$(expand_path ./kubeconfig)

export KUBE_EDITOR=nano

export BWS_ACCESS_TOKEN=$(sops -d cluster/infra/external-secrets/external-secrets/bitwarden-secret/secret.sops.yaml | yq -r '.stringData.token')

export KREWFILE=$(expand_path ./.krewfile)
