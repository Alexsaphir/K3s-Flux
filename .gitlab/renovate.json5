{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    ':disableRateLimiting',
    ':dependencyDashboard',
    ':semanticCommits',
    ':enablePreCommit',
    ':timezone(Europe/Paris)',
    'mergeConfidence:all-badges',
    'local>Homelab/Talos-Flux//.gitlab/renovate/changelogs.json5',
    'local>Homelab/Talos-Flux//.gitlab/renovate/customManagers.json5',
    'local>Homelab/Talos-Flux//.gitlab/renovate/grafanaDashboards.json5',
    'local>Homelab/Talos-Flux//.gitlab/renovate/groups.json5',
    'local>Homelab/Talos-Flux//.gitlab/renovate/labels.json5',
    'local>Homelab/Talos-Flux//.gitlab/renovate/overrides.json5',
    'local>Homelab/Talos-Flux//.gitlab/renovate/packageRules.json5',
    'local>Homelab/Talos-Flux//.gitlab/renovate/semanticCommits.json5',
    'security:openssf-scorecard',
    'github>aquaproj/aqua-renovate-config#2.10.0',
  ],
  dependencyDashboard: true,
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  prConcurrentLimit: 3,
  configWarningReuseIssue: true,
  configMigration: true,
  gitLabIgnoreApprovals: false,
  suppressNotifications: [
    'prEditedNotification',
    'prIgnoreNotification',
  ],
  rebaseWhen: 'behind-base-branch',
  assigneesFromCodeOwners: true,
  reviewersFromCodeOwners: true,
  ignorePaths: [
    '**/*.sops.*',
    '**/archive/**',
  ],
  lockFileMaintenance: {
    enabled: true,
  },
  flux: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
}
